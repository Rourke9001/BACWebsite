{
  "routes": [
    {
      "route": "/admin*",
      "allowedRoles": [
        "blog_author"
      ]
    },
    {
      "route": "/.auth/login/github",
      "statusCode": 404
    },
    {
      "route": "/.auth/login/twitter",
      "statusCode": 404
    },
    {
      "route": "/blog",
      "rewrite": "/api/blog"
    },
    {
      "route": "/blog/*",
      "rewrite": "/api/blog"
    },
    {
      "route": "/sitemap-blog.xml",
      "rewrite": "/api/sitemap-blog.xml"
    },
    {
      "route": "/about.html",
      "redirect": "/about/",
      "statusCode": 301
    },
    {
      "route": "/logistics.html",
      "redirect": "/",
      "statusCode": 301
    },
    {
      "route": "/transport.html",
      "redirect": "/",
      "statusCode": 301
    },
    {
      "route": "/high-value.html",
      "redirect": "/",
      "statusCode": 301
    },
    {
      "route": "/air-freight.html",
      "redirect": "/services/air-freight-services.html",
      "statusCode": 301
    },
    {
      "route": "/sea-freight.html",
      "redirect": "/services/sea-freight-services.html",
      "statusCode": 301
    },
    {
      "route": "/bonded-warehousing.html",
      "redirect": "/services/bonded-warehousing-services.html",
      "statusCode": 301
    },
    {
      "route": "/contact.html",
      "redirect": "/contact/",
      "statusCode": 301
    },
    {
      "route": "/news/bac-logistics-south-africa-an-authorised-economic-operator-aeo.html",
      "redirect": "/blog/bac-logistics-south-africa-an-authorised-economic-operator-aeo.html",
      "statusCode": 301
    }
  ],
  "responseOverrides": {
    "401": {
      "redirect": "/.auth/login/aad?post_login_redirect_uri=/admin/",
      "statusCode": 302
    },
    "404": {
      "rewrite": "/404.html",
      "statusCode": 404
    }
  },
  "mimeTypes": {
    ".xls": "application/vnd.ms-excel",
    ".xlsx": "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
    ".docx": "application/vnd.openxmlformats-officedocument.wordprocessingml.document",
    ".webmanifest": "application/manifest+json"
  }
}